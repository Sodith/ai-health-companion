# ─────────────────────────────────────────────────────────────────────────────
#  AI Health Companion – Production Environment Template
#
#  1. Copy this file to .env  (root of repo, next to docker-compose.yml)
#     cp .env.production.example .env
#
#  2. Fill in every value marked  <CHANGE_ME>
#
#  3. Never commit the resulting .env to git  (.gitignore already covers it)
# ─────────────────────────────────────────────────────────────────────────────

# ── MySQL ─────────────────────────────────────────────────────────────────────
# Use strong, randomly generated passwords (e.g. openssl rand -base64 32)
MYSQL_ROOT_PASSWORD=<CHANGE_ME_STRONG_ROOT_PASSWORD>
MYSQL_DATABASE=health_companion
MYSQL_USER=health_user
MYSQL_PASSWORD=<CHANGE_ME_STRONG_USER_PASSWORD>
# In production the MySQL port is NOT published to the host
# (internal Docker network only). Keep this value for reference.
MYSQL_PORT=3306

# ── Port mappings ─────────────────────────────────────────────────────────────
BACKEND_PORT=8000   # only used locally; in prod nginx fronts the backend
FRONTEND_PORT=80    # EC2 Security Group must allow TCP 80 from 0.0.0.0/0

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with:  openssl rand -hex 64
JWT_SECRET_KEY=<CHANGE_ME_64_CHAR_HEX_SECRET>
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Obtain from https://aistudio.google.com/app/apikey  (free tier)
GEMINI_API_KEY=<CHANGE_ME_GEMINI_API_KEY>

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=AI Health Companion API
APP_ENV=production
APP_DEBUG=false

# ── EC2 / Networking ──────────────────────────────────────────────────────────
# Public IPv4 address (or domain) of your EC2 instance
# Used for CORS_ORIGINS in docker-compose.prod.yml
EC2_PUBLIC_IP=<CHANGE_ME_EC2_PUBLIC_IP>
# Optional custom domain (leave blank if using bare IP)
DOMAIN=

