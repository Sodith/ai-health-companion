# ─────────────────────────────────────────────────────────────────────────────
#  AI Health Companion — Root .env Template
#  Copy to .env and fill in real values before running docker compose up -d
# ─────────────────────────────────────────────────────────────────────────────

# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=health_companion
MYSQL_USER=health_user
MYSQL_PASSWORD=change_me_user_password
MYSQL_PORT=3306

# ── Port mappings (host ports) ────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=80

