# App
APP_NAME=AI Health Companion API
APP_ENV=development
APP_DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=mysql+pymysql://root:root@localhost:3306/ai_health_db

# Security
JWT_SECRET_KEY=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Google Gemini
# Obtain from https://aistudio.google.com/app/apikey  (free tier)
GEMINI_API_KEY=replace_with_your_gemini_api_key

# CORS (JSON array of allowed origins)
CORS_ORIGINS=["http://localhost","http://localhost:4200","http://localhost:80"]

